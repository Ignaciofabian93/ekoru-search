generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================================
// AUTO-GENERATED — do not edit this file directly.
// Source of truth : prisma/schema.prisma  (root master schema)
// Regenerate      : node scripts/generate-schemas.js
// Migrations      : run ONLY from root — npx prisma migrate dev --schema prisma/schema.prisma
// =====================================================================================

// ─── Models ──────────────────────────────────────────────────────────────────────

model SearchLog {
  id          Int           @id @default(autoincrement())
  query       String
  resultCount Int           @default(0)
  userId      String?
  sessionId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  searchClick SearchClick[]

  @@index([createdAt(sort: Desc)])
  @@index([query])
  @@index([sessionId])
  @@index([userId])
}

model SearchClick {
  id        Int       @id @default(autoincrement())
  searchId  Int
  itemId    Int
  itemType  String
  position  Int
  clickedAt DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String?
  searchLog SearchLog @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([clickedAt])
  @@index([itemId, itemType])
  @@index([searchId])
  @@index([userId])
}

model SearchSession {
  id             String    @id
  userId         String?
  sessionId      String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  searchCount    Int      @default(0)
  clickedResults Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sessionId])
  @@index([startedAt])
  @@index([userId])
}

model SearchSuggestion {
  id        Int      @id @default(autoincrement())
  term      String   @unique
  frequency Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([frequency(sort: Desc)])
  @@index([isActive])
  @@index([term])
}

model SearchSynonym {
  id        Int      @id @default(autoincrement())
  term      String
  synonym   String
  weight    Float    @default(1.0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([term, synonym])
  @@index([isActive])
  @@index([term])
}

model SearchCorrection {
  id            Int      @id @default(autoincrement())
  incorrectTerm String
  correctTerm   String
  frequency     Int      @default(1)
  confidence    Float    @default(1.0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([incorrectTerm, correctTerm])
  @@index([frequency(sort: Desc)])
  @@index([incorrectTerm])
  @@index([isActive])
}

model PopularSearch {
  id            Int      @id @default(autoincrement())
  query         String   @unique
  searchCount   Int      @default(0)
  clickCount    Int      @default(0)
  lastSearched  DateTime @default(now())
  trendingScore Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lastSearched(sort: Desc)])
  @@index([searchCount(sort: Desc)])
  @@index([trendingScore(sort: Desc)])
}

model UserSearchHistory {
  id          Int      @id @default(autoincrement())
  userId      String
  query       String
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([query])
  @@index([userId, searchedAt(sort: Desc)])
}

model ItemView {
  id        Int      @id @default(autoincrement())
  userId    String?
  sessionId String?
  itemId    Int
  itemType  String
  viewedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  duration  Int?
  source    String?

  @@index([itemId, itemType])
  @@index([sessionId, viewedAt(sort: Desc)])
  @@index([userId, viewedAt(sort: Desc)])
  @@index([viewedAt])
}

